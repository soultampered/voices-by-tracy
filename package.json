{
  "name": "voices-by-tracy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "mongo": "mongod --dbpath C:\\Users\\unfor\\mongodb\\data --port 27018",
    "mongo:mac": "mkdir -p ~/mongodb-data && mongod --dbpath ~/mongodb-data --port 27018",
    "dev": "cross-env PORT=3000 i18nexus pull && next dev",
    "build": "i18nexus pull && next build",
    "start": "i18nexus pull && NODE_ENV=production node server.js",
    "lint": "i18nexus pull && next lint",
    "seed:media": "node --env-file=.env.local scripts/seedMedia.js",
    "seed:media:prod": "node --env-file=.env.production.local scripts/seedMedia.js",
    "db:setup-indexes": "node --env-file=.env.local lib/db/setupIndexes.js",
    "db:setup-indexes:prod": "node --env-file=.env.production.local lib/db/setupIndexes.js",
    "import:cloudinary": "node --env-file=.env.local scripts/importCloudinaryMedia.js",
    "import:cloudinary:prod": "node --env-file=.env.production.local scripts/importCloudinaryMedia.js",
    "postbuild": "next-sitemap"
  },
  "dependencies": {
    "@chakra-ui/react": "^2.8.2",
    "cloudinary": "^2.9.0",
    "eslint-config-next": "^15.5.20",
    "express-rate-limit": "^7.4.0",
    "i18next": "^23.15.1",
    "i18next-resources-to-backend": "^1.2.1",
    "mongodb": "^7.0.0",
    "next": "^15.5.20",
    "next-i18n-router": "^5.5.8",
    "next-sitemap": "^4.2.3",
    "nodemailer": "^9.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.0.1",
    "react-icons": "^5.3.0",
    "react-modal": "^3.16.1",
    "react-toastify": "^10.0.5",
    "tailwindcss-filters": "^3.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "i18nexus-cli": "^3.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.11"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
